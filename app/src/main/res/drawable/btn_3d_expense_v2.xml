<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:bottom="6dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#60000000" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <item android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="#80FF3B30" />
            <corners android:radius="32dp" />
        </shape>
    </item>

    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#CCFF3B30" />
            <corners android:radius="32dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E6FF3B30" />
            <corners android:radius="32dp" />
            <stroke
                android:width="2dp"
                android:color="#B3FFFFFF" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#80FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90" />
            <corners android:radius="32dp" />
        </shape>
    </item>

    <item android:state_pressed="true" android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#F0FF3B30" />
            <corners android:radius="32dp" />
        </shape>
    </item>
</layer-list>