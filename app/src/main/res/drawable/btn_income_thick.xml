<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:bottom="8dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#60000000" />
            <corners android:radius="36dp" />
        </shape>
    </item>

    <item android:bottom="7dp">
        <shape android:shape="rectangle">
            <solid android:color="#4034C759" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <item android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="#6034C759" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#9034C759" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#CC34C759" />
            <corners android:radius="34dp" />
            <stroke
                android:width="2dp"
                android:color="#B3FFFFFF" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#80FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <item android:state_pressed="true" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#E634C759" />
            <corners android:radius="34dp" />
        </shape>
    </item>
</layer-list>