<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:bottom="6dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#20000000" />
            <corners android:radius="36dp" />
        </shape>
    </item>

    <item android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="#00FF3B30" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#08FF3B30" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#18FF3B30" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#20FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <item android:state_pressed="true" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#30FF3B30" />
            <corners android:radius="34dp" />
        </shape>
    </item>
</layer-list>