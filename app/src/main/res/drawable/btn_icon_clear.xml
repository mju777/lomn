<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 阴影 -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#40000000" />
        </shape>
    </item>

    <!-- 厚度层 -->
    <item android:bottom="5dp" android:left="2dp" android:right="2dp" android:top="2dp">
        <shape android:shape="oval">
            <solid android:color="#08FFFFFF" />
        </shape>
    </item>

    <item android:bottom="3dp">
        <shape android:shape="oval">
            <solid android:color="#12FFFFFF" />
        </shape>
    </item>

    <!-- 玻璃表面 -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#28FFFFFF" />
            <stroke
                android:width="1.5dp"
                android:color="#40FFFFFF" />
        </shape>
    </item>

    <!-- 高光 -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#40FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="45" />
        </shape>
    </item>

    <item android:state_pressed="true" android:bottom="1dp">
        <shape android:shape="oval">
            <solid android:color="#40FFFFFF" />
        </shape>
    </item>
</layer-list>