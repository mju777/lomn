<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 阴影 -->
    <item android:bottom="8dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#60000000" />
            <corners android:radius="36dp" />
        </shape>
    </item>

    <!-- 厚度层1 -->
    <item android:bottom="7dp">
        <shape android:shape="rectangle">
            <solid android:color="#50FFFFFF" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <!-- 厚度层2 -->
    <item android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="#70FFFFFF" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <!-- 厚度层3 -->
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#90FFFFFF" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <!-- 玻璃表层 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#D9FFFFFF" />
            <corners android:radius="34dp" />
            <stroke
                android:width="2dp"
                android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- 高光 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#80FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <!-- 按压态 -->
    <item android:state_pressed="true" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#F0FFFFFF" />
            <corners android:radius="34dp" />
        </shape>
    </item>
</layer-list>