<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 环境阴影 -->
    <item android:bottom="6dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#60000000" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <!-- 玻璃厚度 -->
    <item android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="#8034C759" />
            <corners android:radius="32dp" />
        </shape>
    </item>

    <!-- 玻璃主体 -->
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#CC34C759" />
            <corners android:radius="32dp" />
        </shape>
    </item>

    <!-- 玻璃表面 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E634C759" />
            <corners android:radius="32dp" />
            <stroke
                android:width="2dp"
                android:color="#B3FFFFFF" />
        </shape>
    </item>

    <!-- 高光反射 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#80FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90" />
            <corners android:radius="32dp" />
        </shape>
    </item>

    <item android:state_pressed="true" android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#F034C759" />
            <corners android:radius="32dp" />
        </shape>
    </item>
</layer-list>