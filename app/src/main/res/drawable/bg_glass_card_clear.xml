<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 环境阴影 -->
    <item android:bottom="12dp" android:left="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#40000000" />
            <corners android:radius="44dp" />
        </shape>
    </item>

    <!-- 玻璃厚度层 -->
    <item android:bottom="10dp">
        <shape android:shape="rectangle">
            <solid android:color="#08FFFFFF" />
            <corners android:radius="42dp" />
        </shape>
    </item>

    <item android:bottom="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#10FFFFFF" />
            <corners android:radius="42dp" />
        </shape>
    </item>

    <item android:bottom="6dp">
        <shape android:shape="rectangle">
            <solid android:color="#15FFFFFF" />
            <corners android:radius="42dp" />
        </shape>
    </item>

    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#18FFFFFF" />
            <corners android:radius="42dp" />
        </shape>
    </item>

    <item android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#20FFFFFF" />
            <corners android:radius="42dp" />
        </shape>
    </item>

    <!-- 玻璃主体 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#28FFFFFF" />
            <corners android:radius="42dp" />
            <stroke
                android:width="1.5dp"
                android:color="#40FFFFFF" />
        </shape>
    </item>

    <!-- 高光反射 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#30FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90" />
            <corners android:radius="42dp" />
        </shape>
    </item>
</layer-list>