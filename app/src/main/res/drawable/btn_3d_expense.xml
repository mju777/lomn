<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:bottom="4dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#40000000" />
            <corners android:radius="32dp" />
        </shape>
    </item>

    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#60FF3B30" />
            <corners android:radius="30dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#CCFF3B30" />
            <corners android:radius="30dp" />
            <stroke
                android:width="1.5dp"
                android:color="#80FFFFFF" />
        </shape>
    </item>

    <item android:state_pressed="true" android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#E5FF3B30" />
            <corners android:radius="30dp" />
        </shape>
    </item>
</layer-list>