<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 极淡阴影 -->
    <item android:bottom="10dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#20000000" />
            <corners android:radius="44dp" />
        </shape>
    </item>

    <!-- 厚度层（无白边） -->
    <item android:bottom="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#00FFFFFF" />
            <corners android:radius="42dp" />
        </shape>
    </item>

    <item android:bottom="6dp">
        <shape android:shape="rectangle">
            <solid android:color="#03FFFFFF" />
            <corners android:radius="42dp" />
        </shape>
    </item>

    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#05FFFFFF" />
            <corners android:radius="42dp" />
        </shape>
    </item>

    <item android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#08FFFFFF" />
            <corners android:radius="42dp" />
        </shape>
    </item>

    <!-- 玻璃主体（超高透明） -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#12FFFFFF" />
            <corners android:radius="42dp" />
        </shape>
    </item>

    <!-- 极淡高光 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#18FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90" />
            <corners android:radius="42dp" />
        </shape>
    </item>
</layer-list>