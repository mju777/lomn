<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 环境阴影 -->
    <item android:bottom="8dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#40000000" />
            <corners android:radius="36dp" />
        </shape>
    </item>

    <!-- 玻璃厚度层1 -->
    <item android:bottom="7dp">
        <shape android:shape="rectangle">
            <solid android:color="#08FFFFFF" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <!-- 玻璃厚度层2 -->
    <item android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="#12FFFFFF" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <!-- 玻璃厚度层3 -->
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#18FFFFFF" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <!-- 玻璃主体（纯透明玻璃色） -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#28FFFFFF" />
            <corners android:radius="34dp" />
            <stroke
                android:width="1.5dp"
                android:color="#40FFFFFF" />
        </shape>
    </item>

    <!-- 顶部高光反射 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#30FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <!-- 按压态 -->
    <item android:state_pressed="true" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#40FFFFFF" />
            <corners android:radius="34dp" />
        </shape>
    </item>
</layer-list>