<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:bottom="8dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#40000000" />
            <corners android:radius="36dp" />
        </shape>
    </item>

    <item android:bottom="7dp">
        <shape android:shape="rectangle">
            <solid android:color="#08FF3B30" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <item android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="#12FF3B30" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#20FF3B30" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#40FF3B30" />
            <corners android:radius="34dp" />
            <stroke
                android:width="1.5dp"
                android:color="#60FFFFFF" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#40FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <item android:state_pressed="true" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#60FF3B30" />
            <corners android:radius="34dp" />
        </shape>
    </item>
</layer-list>