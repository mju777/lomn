<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 极淡阴影 -->
    <item android:bottom="6dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#20000000" />
            <corners android:radius="36dp" />
        </shape>
    </item>

    <!-- 厚度层 -->
    <item android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="#0034C759" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#0834C759" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <!-- 玻璃主体 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1834C759" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <!-- 极淡高光 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#20FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <!-- 按压态 -->
    <item android:state_pressed="true" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#3034C759" />
            <corners android:radius="34dp" />
        </shape>
    </item>
</layer-list>