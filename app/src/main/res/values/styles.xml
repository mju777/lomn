<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">#FFFBC5</item>  <!-- 深邃的蓝色，类似于海洋的颜色 -->
        <item name="colorPrimaryDark">#FFFBC5</item>  <!-- 稍深的蓝色，增加层次感 -->
        <item name="colorAccent">#FFFBC5</item>  <!-- 一种淡蓝色，带来清新和宁静感 -->
    </style>


    <style name="CustomSpinnerStyle" parent="@android:style/Widget.TextView.SpinnerItem">
        <item name="android:textSize">26sp</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="CalendarDateText"></style>



    <!-- Switch 金色主题 -->
    <style name="SwitchTheme" parent="Theme.AppCompat.Light">
        <item name="colorControlActivated">#D4AF37</item>
        <item name="colorSwitchThumbNormal">#E0E0E0</item>
        <item name="android:colorForeground">#D4AF37</item>
    </style>

    <style name="CustomSpinnerStyle1" parent="Theme.AppCompat.Light">
        <item name="android:popupBackground">#FFFFFF</item>
        <item name="android:background">@drawable/spinner_background</item>
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">14sp</item>
    </style>


</resources>
