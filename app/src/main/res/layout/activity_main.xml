<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fitsSystemWindows="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <!-- 头部 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/title_app"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰 小金库"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:shadowColor="#80000000"
                    android:shadowDx="2"
                    android:shadowDy="2"
                    android:shadowRadius="4" />

                <TextClock
                    android:id="@+id/textClock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:format12Hour="hh:mm:ss"
                    android:format24Hour="HH:mm:ss"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:shadowColor="#80000000"
                    android:shadowDx="2"
                    android:shadowDy="2"
                    android:shadowRadius="4" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_home_settings"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/btn_icon_ultraclear"
                    android:text="⚙️"
                    android:textSize="24sp" />

                <Button
                    android:id="@+id/button_share"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/btn_icon_ultraclear"
                    android:text="📤"
                    android:textSize="24sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 资产卡片 -->
        <LinearLayout
            android:id="@+id/card_asset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_glass_card_ultraclear"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/label_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="总资产"
                android:textColor="#CCCCCC"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="0.00"
                android:textColor="#FFFFFF"
                android:textSize="44sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/label_income"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📈 总收入"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_income"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="0.00"
                        android:textColor="#4CD964"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="40dp"
                    android:background="#30FFFFFF" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="20dp">

                    <TextView
                        android:id="@+id/label_pay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📉 总支出"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_pay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="0.00"
                        android:textColor="#FF3B30"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 快捷操作 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="16dp"
            android:text="⚡ 快捷操作"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:shadowColor="#80000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_new_record"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/btn_glass_ultraclear"
                android:gravity="center"
                android:text="📝 记账"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/button_records"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/btn_glass_ultraclear"
                android:gravity="center"
                android:text="📋 记录"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/button_new_account"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/btn_glass_ultraclear"
                android:gravity="center"
                android:text="🏦 账户"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 快速记账 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:text="➕ 快速记账"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:shadowColor="#80000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_income_quick"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/btn_income_ultraclear"
                android:gravity="center"
                android:text="💰 收入"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_expense_quick"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/btn_expense_ultraclear"
                android:gravity="center"
                android:text="💸 支出"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 更多功能 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:text="🔧 更多功能"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:shadowColor="#80000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_main_about_me"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/btn_glass_ultraclear"
                android:gravity="center"
                android:text="ℹ️ 关于"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/button_main_pls"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/btn_glass_ultraclear"
                android:gravity="center"
                android:text="👍 点赞"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/button_main_back"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/btn_glass_ultraclear"
                android:gravity="center"
                android:text="← 返回"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="40dp" />

    </LinearLayout>
</ScrollView>