<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layout_gravity="center"
    android:background="#FFFBC5">  <!-- 背景改为米白色 -->

    <LinearLayout
        android:orientation="vertical"
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center">
        <View
            android:id="@+id/status_bar_placeholder_qu"
            android:layout_width="match_parent"
            android:layout_height="3333dp" />

        <Button
            android:layout_marginTop="44dp"
            android:id="@+id/button_quickly"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="#FFFBC5"
            android:text="@string/quickly">
        </Button>
    <Button
        android:layout_marginTop="44dp"
        android:id="@+id/button_quickly_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:background="#FFFBC5"
        android:text="@string/back">

    </Button>

        <View
            android:id="@+id/status_bar_placeholder"
            android:layout_width="match_parent"
            android:layout_height="1111dp" />

</LinearLayout>
</ScrollView>