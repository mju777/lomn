<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:orientation="vertical">

    <!-- 状态栏占位 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="32dp" />

    <!-- 头部 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <Button
            android:id="@+id/button_records_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/btn_icon_round"
            android:text="←"
            android:textSize="24sp"
            android:textColor="#D4AF37" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📋 记账记录"
            android:textColor="#1A1A1A"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:visibility="invisible" />
    </LinearLayout>

    <!-- 装饰金线 -->
    <View
        android:layout_width="80dp"
        android:layout_height="3dp"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"
        android:background="@drawable/gold_line" />

    <!-- 统计卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/card_dark_bg"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💰 当前显示"
            android:textColor="#888888"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/text_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/all"
            android:textColor="#D4AF37"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="总条数"
                android:textColor="#888888"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_total_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#D4AF37"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- 筛选按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <Button
            android:id="@+id/button_records_all"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/btn_filter_all"
            android:gravity="center"
            android:text="📋 全部"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/button_records_income"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/btn_filter_income"
            android:gravity="center"
            android:text="📈 收入"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/button_records_pay"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/btn_filter_expense"
            android:gravity="center"
            android:text="📉 支出"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 列表区域 - 使用 ListView 直接作为可滚动视图 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/card_white_bg"
        android:orientation="vertical"
        android:padding="4dp">

        <ListView
            android:id="@+id/record_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="#F0F0F0"
            android:dividerHeight="1dp"
            tools:ignore="NestedScrolling" />

        <!-- 空视图 -->
        <LinearLayout
            android:id="@+id/empty_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📭"
                android:textSize="64sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="暂无记录"
                android:textColor="#888888"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="点击首页「新增记录」开始记账"
                android:textColor="#BBBBBB"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>