<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="48dp">

        <!-- 状态栏占位 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

        <!-- 头部 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp">

            <Button
                android:id="@+id/button_quick_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/btn_icon_round"
                android:text="←"
                android:textSize="24sp"
                android:textColor="#D4AF37" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="⚡ 快捷记账"
                android:textColor="#1A1A1A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <View
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- 装饰金线 -->
        <View
            android:layout_width="80dp"
            android:layout_height="3dp"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:background="@drawable/gold_line" />

        <!-- 类型切换按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_quick_income"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/btn_income_selected"
                android:gravity="center"
                android:text="📈 收入"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_quick_expense"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/btn_expense"
                android:gravity="center"
                android:text="📉 支出"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 表单卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/card_white_bg"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 金额输入（大号字体） -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💰 金额"
                android:textColor="#D4AF37"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_quick_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/edittext_background"
                android:gravity="center"
                android:hint="0.00"
                android:inputType="numberDecimal"
                android:padding="16dp"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- 分类选择 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="📂 选择分类"
                android:textColor="#D4AF37"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- 常用分类快捷按钮 -->
            <LinearLayout
                android:id="@+id/layout_quick_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                android:orientation="vertical">

                <!-- 第一行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/category_food"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/btn_category"
                        android:gravity="center"
                        android:text="🍜 餐饮"
                        android:textAllCaps="false"
                        android:textColor="#555555"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/category_shopping"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:layout_weight="1"
                        android:background="@drawable/btn_category"
                        android:gravity="center"
                        android:text="🛒 购物"
                        android:textAllCaps="false"
                        android:textColor="#555555"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/category_transport"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/btn_category"
                        android:gravity="center"
                        android:text="🚗 交通"
                        android:textAllCaps="false"
                        android:textColor="#555555"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- 第二行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/category_entertainment"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/btn_category"
                        android:gravity="center"
                        android:text="🎬 娱乐"
                        android:textAllCaps="false"
                        android:textColor="#555555"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/category_salary"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:layout_weight="1"
                        android:background="@drawable/btn_category"
                        android:gravity="center"
                        android:text="💰 工资"
                        android:textAllCaps="false"
                        android:textColor="#555555"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/category_other"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/btn_category"
                        android:gravity="center"
                        android:text="📦 其他"
                        android:textAllCaps="false"
                        android:textColor="#555555"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 自定义分类输入 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="✏️ 自定义分类"
                android:textColor="#888888"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/et_quick_category"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/edittext_background"
                android:gravity="center"
                android:hint="或手动输入分类"
                android:inputType="text"
                android:padding="12dp"
                android:textSize="14sp" />

            <!-- 账户选择 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="🏦 账户"
                android:textColor="#D4AF37"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinner_account"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/spinner_background"
                android:entries="@array/account_types"
                android:gravity="center"
                android:padding="12dp"
                android:theme="@style/CustomSpinnerStyle1" />

            <!-- 备注 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="📝 备注（可选）"
                android:textColor="#888888"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/et_quick_note"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/edittext_background"
                android:gravity="center"
                android:hint="添加备注..."
                android:inputType="text"
                android:padding="12dp"
                android:textSize="14sp" />

            <!-- 保存按钮 -->
            <Button
                android:id="@+id/btn_quick_save"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/btn_gold_luxury"
                android:gravity="center"
                android:text="💾 一键保存"
                android:textAllCaps="false"
                android:textColor="#1A1A1A"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 提示卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/card_dark_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="⚡ 快捷小贴士"
                android:textColor="#D4AF37"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="点击分类按钮快速选择，金额支持小数点后两位"
                android:textColor="#CCCCCC"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>