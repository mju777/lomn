<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layout_gravity="center"
    android:background="#FFFBC5"
    tools:ignore="ScrollViewCount">  <!-- 背景改为米白色 -->

    <LinearLayout
        android:orientation="vertical"
        android:layout_gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center">

        <View

            android:layout_width="match_parent"
            android:layout_height="1111dp" />

        <TextView
            android:layout_marginTop="44dp"

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/income"
            android:textColor="#000000"
            android:textSize="16sp"
            android:gravity="center" />

        <TextView
            android:layout_marginTop="44dp"

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/incometype"
            android:textColor="#000000"
            android:textSize="16sp"
            android:gravity="center" />

        <Spinner
            android:layout_marginTop="44dp"

            android:id="@+id/new_income_source"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:theme="@style/CustomSpinnerStyle"
            android:entries="@array/income_from"
            android:textColor="#000000"
            android:textAlignment="center"
            android:layout_gravity="center"
            android:gravity="center"/>

        <TextView
            android:layout_marginTop="44dp"

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/incomesource"
            android:textColor="#000000"
            android:textSize="16sp"
            android:gravity="center" />

        <Spinner
            android:layout_marginTop="44dp"

            android:id="@+id/new_income_type"
            android:layout_width="match_parent"
            android:theme="@style/CustomSpinnerStyle"
            android:layout_height="wrap_content"
            android:entries="@array/income_to"
            android:textColor="#000000"
            android:textAlignment="center"
            android:layout_gravity="center"
            android:gravity="center"/>

        <TextView
            android:layout_marginTop="44dp"

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/incomeaccount"
            android:textColor="#000000"
            android:textSize="16sp"
            android:gravity="center" />

        <EditText
            android:layout_marginTop="44dp"

            android:id="@+id/new_income_account"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints=""
            android:maxLines="1"
            android:inputType="text"
            android:singleLine="true"
            android:textSize="16sp"
            android:gravity="center"
            android:hint="@string/Pleaseenterthecontent"
            />

        <TextView
            android:layout_marginTop="44dp"

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/incomeamount"
            android:textColor="#000000"
            android:textSize="16sp"
            android:gravity="center"
            />

        <EditText
            android:layout_marginTop="44dp"

            android:id="@+id/new_income_amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints=""
            android:inputType="numberDecimal"
            android:textSize="16sp"
            android:maxLength="16"
            android:gravity="center"
            android:singleLine="true"
            android:hint="@string/Pleaseenterthecontent"
            />  <!-- 输入内容不可换行 -->

        <Button
            android:layout_marginTop="44dp"

            android:background="#FFFBC5"
            android:id="@+id/button_new_income_record"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="@string/btn_records"
            android:textSize="16sp"
            android:textColor="#000000"
            android:gravity="center" />
        <Button
            android:layout_marginTop="44dp"

            android:background="#FFFBC5"
            android:id="@+id/button_new_income_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back"
            android:textSize="16sp"
            android:textColor="#000000"
            android:gravity="center" />
    </LinearLayout>
</ScrollView>